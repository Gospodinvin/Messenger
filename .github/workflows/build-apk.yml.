name: Build Android APK
on:
  workflow_dispatch: # Позволяет запускать сборку вручную из интерфейса GitHub
jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      # 1. Получаем код из вашего репозитория
      - uses: actions/checkout@v4

      # 2. Устанавливаем Java и Android SDK для сборки
      - name: Set up JDK 17
        uses: actions/setup-java@v4
        with:
          java-version: '17'
          distribution: 'temurin'
      - name: Setup Android SDK
        uses: android-actions/setup-android@v3

      # 3. Устанавливаем Node.js и зависимости
      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '18'
      - name: Install dependencies
        run: npm install

      # 4. Готовим проект и собираем APK
      - name: Build APK
        run: |
          npx expo prebuild --platform android --clean
          cd android
          chmod +x gradlew
          ./gradlew assembleDebug

      # 5. Загружаем готовый APK обратно в GitHub
      - name: Upload APK
        uses: actions/upload-artifact@v4
        with:
          name: app-debug
          path: android/app/build/outputs/apk/debug/app-debug.apk
